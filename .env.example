# TenClaw Environment Configuration
# Copy this file to .env and fill in your values (never commit .env to git)

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider Configuration (choose one)
# ─────────────────────────────────────────────────────────────────────────────

# Option 1: OpenAI (cloud)
OPENAI_API_KEY=sk-xxx

# Option 2: Anthropic (cloud)
ANTHROPIC_API_KEY=sk-ant-xxx

# Option 3: Local LLM (no API key needed)
# LLM_PROVIDER=lmstudio
# LLM_PROVIDER=ollama

# Optional: Custom base URL for OpenAI-compatible endpoints
# OPENAI_BASE_URL=http://localhost:1234/v1

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure (default values work with docker-compose.yml)
# ─────────────────────────────────────────────────────────────────────────────

REDIS_URL=redis://127.0.0.1:6379
CHROMA_URL=http://127.0.0.1:8000

# ─────────────────────────────────────────────────────────────────────────────
# Demo Configuration
# ─────────────────────────────────────────────────────────────────────────────

TENANT_ID=demo-tenant
WORKSPACE_ID=demo-workspace
PROJECT_ID=demo-project
ENVIRONMENT=dev
TEAM_ID=dev-team

# ─────────────────────────────────────────────────────────────────────────────
# Optional: Paths (defaults work with project structure)
# ─────────────────────────────────────────────────────────────────────────────

TEAMS_ROOT=./teams
SKILLS_ROOT=./skills
