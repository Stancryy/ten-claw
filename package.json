{
  "name": "tenclaw",
  "version": "0.1.0",
  "description": "Production-oriented TypeScript multi-agent orchestration framework with pluggable memory, workflow persistence, and multi-LLM backends.",
  "license": "UNLICENSED",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "teams",
    "skills"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true });\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "demo": "npx ts-node examples/run.ts",
    "skills:review": "npx ts-node scripts/skills-review.ts",
    "dashboard": "npx ts-node src/dashboard/server.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.33.0",
    "chromadb": "^2.0.0",
    "chromadb-default-embed": "^2.14.0",
    "dotenv": "^17.4.1",
    "ioredis": "^5.6.0",
    "js-tiktoken": "^1.0.15",
    "openai": "^4.77.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.30",
    "typescript": "^5.4.5"
  }
}
